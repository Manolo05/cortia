{
  "manifest_version": 3,
  "name": "CortIA",
  "version": "1.0.0",
  "description": "Extension CortIA pour les courtiers en prêt immobilier",
  
  "permissions": [
    "activeTab",
    "storage",
    "sidePanel"
  ],
  
  "host_permissions": [
    "https://*.cortia.app/*",
    "http://localhost:3000/*"
  ],
  
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/detector.js"],
      "run_at": "document_idle"
    }
  ],
  
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "CortIA"
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
